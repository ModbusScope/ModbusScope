{
  "permissions": {
    "allow": [
      "Read",
      "Bash(cmake:*)",
      "Bash(ctest:*)",
      "Bash(make:*)",
      "Bash(ninja:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(clang-tidy:*)",
      "Bash(clazy:*)",
      "Bash(/scripts/run_precommit.sh:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.*)",
      "Read(**/license_keys.*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}